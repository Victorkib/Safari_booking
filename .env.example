# Safari Booking System — Environment Variables

# Neon Postgres connection string (from Neon dashboard → Connection Details)
DATABASE_URL=postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

# Public site URL (SEO canonical, sitemap, Open Graph — use production domain when deployed)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# App URL for Better Auth callbacks (local dev; can match NEXT_PUBLIC_SITE_URL)
BETTER_AUTH_URL=http://localhost:3000

# Random secret for session signing (generate with: openssl rand -base64 32)
BETTER_AUTH_SECRET=your-secret-here

# Transactional email — Mailjet (primary), Gmail app password (fallback)
# If both unset, dev mode logs to console instead of sending
EMAIL_FROM=Safari Adventures <bookings@safariadventures.com>
ADMIN_EMAIL=admin@safari.test

# Mailjet (primary) — https://app.mailjet.com/account/apikeys
MAILJET_API_KEY=your-mailjet-api-key
MAILJET_SECRET_KEY=your-mailjet-secret-key

# Gmail SMTP (secondary fallback) — use a Google App Password, not your account password
# https://myaccount.google.com/apppasswords
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# M-Pesa Daraja API (Safaricom) — STK Push live payments
# Leave unset to use manual verification mode in development
MPESA_CONSUMER_KEY=your-consumer-key
MPESA_CONSUMER_SECRET=your-consumer-secret
MPESA_PASSKEY=your-lipa-na-mpesa-passkey
MPESA_SHORTCODE=174379
MPESA_ENV=sandbox
# Public HTTPS URL — use ngrok/cloudflare tunnel for local callback testing
MPESA_CALLBACK_URL=https://your-domain.com/api/mpesa/callback
MPESA_ACCOUNT_REFERENCE=SafariAdventures

# Database maintenance (CLI only — no admin UI)
# Set only when intentionally wiping production data:
# CONFIRM_DB_CLEAR=yes
