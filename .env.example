# Safari Booking System — Environment Variables

# Neon Postgres connection string (from Neon dashboard → Connection Details)
DATABASE_URL=postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

# App URL for Better Auth callbacks (local dev)
BETTER_AUTH_URL=http://localhost:3000

# Random secret for session signing (generate with: openssl rand -base64 32)
BETTER_AUTH_SECRET=your-secret-here
